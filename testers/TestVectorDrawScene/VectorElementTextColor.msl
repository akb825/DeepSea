#include <DeepSea/Scene/Shaders/ViewFramebuffer.mslh>
#if DISCARD_BOUNDS
#include <DeepSea/SceneVectorDraw/Shaders/InstanceDiscardBounds.mslh>
#endif
#include <DeepSea/VectorDraw/Shaders/VectorElementTextColor.mslh>

#if DISCARD_BOUNDS
varying(vertex, fragment)
{
	vec2 vfDiscardPos;
}
#endif

[[vertex]]
void vectorTextColorVertex()
{
	gl_Position = dsVectorElementText_processVertex();
#if DISCARD_BOUNDS
	vfDiscardPos = dsInstanceDiscardBounds_toDiscardSpace(gl_Position.xyz);
#endif
	gl_Position.xy = dsViewFramebuffer_rotateFramebufferPosition(gl_Position.xy);
	gl_Position = DS_ADJUST_CLIP(gl_Position);
}

[[fragment]]
void vectorTextFragmentColor()
{
#if DISCARD_BOUNDS
	dsInstanceDiscardBounds_clip(vfDiscardPos);
#endif
	dsVectorElementText_defaultFragmentColor();
}

[[fragment]]
void vectorTextFragmentColorOutline()
{
#if DISCARD_BOUNDS
	dsInstanceDiscardBounds_clip(vfDiscardPos);
#endif
	dsVectorElementText_defaultFragmentColorOutline();
}

pipeline dsVectorTextColor
{
	vertex = vectorTextColorVertex;
	fragment = vectorTextFragmentColor;
	DS_DEFAULT_VECTOR_ELEMENT_TEXT_RENDER_STATES;
}

pipeline dsVectorTextColorOutline
{
	vertex = vectorTextColorVertex;
	fragment = vectorTextFragmentColorOutline;
	DS_DEFAULT_VECTOR_ELEMENT_TEXT_RENDER_STATES;
}
