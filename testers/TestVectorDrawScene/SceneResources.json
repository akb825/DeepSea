[
	{
		"type": "ShaderVariableGroupDesc",
		"name": "viewFramebufferDesc",
		"elements":
		[
			{"name": "framebufferSize", "type": "IVec4"},
			{"name": "framebufferRotation", "type": "Vec4"}
		]
	},
	{
		"type": "ShaderVariableGroupDesc",
		"name": "instanceScreenTransformDesc",
		"elements":
		[
			{"name": "world", "type": "Mat4"},
			{"name": "worldProj", "type": "Mat4"}
		]
	},
	{
		"type": "ShaderVariableGroupDesc",
		"name": "instanceDiscardBoundsDesc",
		"elements":
		[
			{"name": "discardWorldProjInv", "type": "Mat4"},
			{"name": "discardBounds", "type": "Vec4"}
		]
	},
	{
		"type": "MaterialDesc",
		"name": "textMaterialDesc",
		"elements":
		[
			{
				"name": "dsViewFramebufferData",
				"type": "VariableGroup",
				"binding": "Instance",
				"shaderVariableGroupDesc": "viewFramebufferDesc"
			},
			{
				"name": "dsInstanceScreenTransformData",
				"type": "VariableGroup",
				"binding": "Instance",
				"shaderVariableGroupDesc": "instanceScreenTransformDesc"
			},
			{
				"name": "dsInstanceDiscardBoundsData",
				"type": "VariableGroup",
				"binding": "Instance",
				"shaderVariableGroupDesc": "instanceDiscardBoundsDesc"
			},
			{
				"name": "dsFontTex",
				"type": "Texture",
				"binding": "Instance"
			}
		]
	},
	{
		"type": "VectorShaders",
		"name": "vectorShaders",
		"modules": @vectorModule@,
		"materialDesc": "vectorMaterialDesc",
		"extraElements":
		[
			{
				"name": "dsViewFramebufferData",
				"type": "VariableGroup",
				"binding": "Instance",
				"shaderVariableGroupDesc": "viewFramebufferDesc"
			},
			{
				"name": "dsInstanceDiscardBoundsData",
				"type": "VariableGroup",
				"binding": "Instance",
				"shaderVariableGroupDesc": "instanceDiscardBoundsDesc"
			}
		]
	},
	{
		"type": "VectorResources",
		"name": "resources",
		"resources":
		[
			{
				"type": "FaceGroup",
				"name": "default",
				"faces":
				[
					{
						"name": "sans",
						"path": "../Shared/Fonts/NotoSans-Regular.ttc"
					}
				]
			},
			{
				"type": "VectorImage",
				"path": "../Shared/Icons/SVGs/one.svg",
				"targetSize": [32, 32]
			},
			{
				"type": "VectorImage",
				"path": "../Shared/Icons/SVGs/cat.svg",
				"targetSize": [32, 32]
			},
			{
				"type": "VectorTextIcons",
				"name": "icons",
				"icons":
				[
					[
						{
							"codepoint": 49,
							"icon": "one",
							"advance": 0.8,
							"bounds": [[-0.2, -0.2], [1.0, 1.0]]
						}
					],
					[
						{
							"codepoint": "0x1F431",
							"icon": "cat",
							"advance": 0.8,
							"bounds": [[-0.2, -0.2], [1.0, 1.0]]
						}
					]
				]
			},
			{
				"type": "Font",
				"name": "sans-serif",
				"faceGroup": "default",
				"faces": ["sans"],
				"icons": "icons",
				"quality": "high"
			}
		],
		"output": "VectorResources.dsvr",
		"vectorShaders": "vectorShaders"
	},
	{
		"type": "VectorImage",
		"name": "tiger",
		"image": "Ghostscript_Tiger.svg",
		"vectorShaders": "vectorShaders",
		"targetSize": [75, 75]
	},
	{
		"type": "VectorImage",
		"name": "borderStraight",
		"image": "BorderStraight.svg",
		"vectorShaders": "vectorShaders",
		"targetSize": [8, 8]
	},
	{
		"type": "VectorImage",
		"name": "borderCorner",
		"image": "BorderCorner.svg",
		"vectorShaders": "vectorShaders",
		"targetSize": [8, 8]
	},
	{
		"type": "Text",
		"name": "figure",
		"vectorResources": "resources",
		"font": "sans-serif",
		"text": "<text font-size=\"8\" fill=\"black\"><tspan font-style=\"italic\">Figure ${tigerNum}:</tspan> an SVG tiger. 🐱</text>"
	},
	{
		"type": "ShaderModule",
		"name": "textModule",
		"modules": @textModule@
	},
	{
		"type": "Shader",
		"name": "textShader",
		"module": "textModule",
		"pipeline": "Text",
		"materialDesc": "textMaterialDesc"
	},
	{
		"type": "SceneNode",
		"nodeType": "TextNode",
		"name": "figureNode",
		"text": "figure",
		"alignment": "Center",
		"maxWidth": 50,
		"lineScale": 1.2,
		"shader": "textShader",
		"z": 1,
		"itemLists": ["vectorDrawPrepare", "vectorItemList"]
	},
	{
		"type": "SceneNode",
		"nodeType": "VectorImageNode",
		"name": "borderStraightNode",
		"vectorImage": "borderStraight",
		"vectorShaders": "vectorShaders",
		"size": [4, 4],
		"z": 0,
		"itemLists": ["vectorDrawPrepare", "vectorItemList"]
	},
	{
		"type": "SceneNode",
		"nodeType": "VectorImageNode",
		"name": "borderCornerNode",
		"vectorImage": "borderCorner",
		"vectorShaders": "vectorShaders",
		"size": [4, 4],
		"z": 0,
		"itemLists": ["vectorDrawPrepare", "vectorItemList"]
	},
	{
		"type": "SceneNode",
		"nodeType": "TransformNode",
		"name": "figureOffsetNode",
		"children":
		[
			{"nodeType": "ReferenceNode", "ref": "figureNode"}
		]
	},
	{
		"type": "SceneNode",
		"nodeType": "TransformNode",
		"name": "textBoxNode",
		"comment": "50 x 12 text box with a border, origin in the middle of the upper text line.",
		"children":
		[
			{
				"nodeType": "TransformNode",
				"comment": "Upper-left corner.",
				"transformList":
				[
					{"type": "Translate", "value": [-29, 4, 0]}
				],
				"children":
				[
					{"nodeType": "ReferenceNode", "ref": "borderCornerNode"}
				]
			},
			{
				"nodeType": "TransformNode",
				"comment": "Upper edge.",
				"transformList":
				[
					{"type": "Scale", "value": [12.5, 1, 1]},
					{"type": "Translate", "value": [-25, 4, 0]}
				],
				"children":
				[
					{"nodeType": "ReferenceNode", "ref": "borderStraightNode"}
				]
			},
			{
				"nodeType": "TransformNode",
				"comment": "Upper-right corner.",
				"transformList":
				[
					{"type": "Rotate", "value": [0, 0, -90]},
					{"type": "Translate", "value": [25, 8, 0]}
				],
				"children":
				[
					{"nodeType": "ReferenceNode", "ref": "borderCornerNode"}
				]
			},
			{
				"nodeType": "TransformNode",
				"comment": "Right edge.",
				"transformList":
				[
					{"type": "Scale", "value": [2, 1, 1]},
					{"type": "Rotate", "value": [0, 0, -90]},
					{"type": "Translate", "value": [25, 4, 0]}
				],
				"children":
				[
					{"nodeType": "ReferenceNode", "ref": "borderStraightNode"}
				]
			},
			{
				"nodeType": "TransformNode",
				"comment": "Lower-right corner.",
				"transformList":
				[
					{"type": "Rotate", "value": [0, 0, 180]},
					{"type": "Translate", "value": [29, -4, 0]}
				],
				"children":
				[
					{"nodeType": "ReferenceNode", "ref": "borderCornerNode"}
				]
			},
			{
				"nodeType": "TransformNode",
				"comment": "Bottom edge.",
				"transformList":
				[
					{"type": "Scale", "value": [12.5, 1, 1]},
					{"type": "Rotate", "value": [0, 0, 180]},
					{"type": "Translate", "value": [25, -4, 0]}
				],
				"children":
				[
					{"nodeType": "ReferenceNode", "ref": "borderStraightNode"}
				]
			},
			{
				"nodeType": "TransformNode",
				"comment": "Lower-left corner.",
				"transformList":
				[
					{"type": "Rotate", "value": [0, 0, 90]},
					{"type": "Translate", "value": [-25, -8, 0]}
				],
				"children":
				[
					{"nodeType": "ReferenceNode", "ref": "borderCornerNode"}
				]
			},
			{
				"nodeType": "TransformNode",
				"comment": "Left edge.",
				"transformList":
				[
					{"type": "Scale", "value": [2, 1, 1]},
					{"type": "Rotate", "value": [0, 0, 90]},
					{"type": "Translate", "value": [-25, -4, 0]}
				],
				"children":
				[
					{"nodeType": "ReferenceNode", "ref": "borderStraightNode"}
				]
			},
			{
				"nodeType": "DiscardBoundsNode",
				"discardBounds": [[-25, -6.5], [25, 6.5]],
				"children":
				[
					{"nodeType": "ReferenceNode", "ref": "figureOffsetNode"}
				]
			}
		]
	},
	{
		"type": "SceneNode",
		"nodeType": "TransformNode",
		"name": "figureTransformNode",
		"transformList":
		[
			{"type": "Translate", "value": [0, 12, 0]}
		],
		"children":
		[
			{"nodeType": "ReferenceNode", "ref": "figureNode"}
		]
	},
	{
		"type": "SceneNode",
		"nodeType": "TransformNode",
		"name": "rootNode",
		"transformList":
		[
			{"type": "Translate", "value": [50, 0, 0]}
		],
		"children":
		[
			{
				"nodeType": "TransformNode",
				"transformList":
				[
					{"type": "Translate", "value": [-37.5, 20, 0]}
				],
				"children":
				[
					{
						"nodeType": "VectorImageNode",
						"vectorImage": "tiger",
						"vectorShaders": "vectorShaders",
						"size": [75, 75],
						"z": 0,
						"itemLists": ["vectorDrawPrepare", "vectorItemList"]
					}
				]
			},
			{"nodeType": "ReferenceNode", "ref": "figureTransformNode"}
		]
	}
]
